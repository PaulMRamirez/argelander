{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://argelander.dev/schemas/strip.schema.json",
  "title": "Strip",
  "description": "Draft seed; Phase 0 completes this against SPEC-STRIP. TODO markers are Phase 0 items.",
  "type": "object",
  "required": [
    "id",
    "body",
    "frame",
    "instrumentId",
    "segments",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "body": {
      "type": "string",
      "minLength": 1
    },
    "frame": {
      "type": "string",
      "minLength": 1
    },
    "instrumentId": {
      "type": "string",
      "minLength": 1
    },
    "missionId": {
      "type": "string"
    },
    "mode": {
      "type": "string"
    },
    "passId": {
      "type": "string"
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "etSec",
          "left",
          "right",
          "state"
        ],
        "properties": {
          "etSec": {
            "type": "number"
          },
          "left": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 3,
            "maxItems": 3
          },
          "right": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 3,
            "maxItems": 3
          },
          "state": {
            "enum": [
              "planned",
              "acquiring",
              "committed"
            ]
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "authority",
        "generatedBy"
      ],
      "properties": {
        "authority": {
          "type": "string",
          "minLength": 1
        },
        "generatedBy": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
